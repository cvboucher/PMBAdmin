@page "/dmv-codes"
@page "/dmv_code_grid"
@attribute [Authorize(Policy = AppPermissions.DmvCodesView)]

@inject IDbContextFactory<PMBContext> DbFactory
@inject DialogService DialogService

<PageTitle>DMV Codes</PageTitle>

<RadzenCard>
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-3">
        <RadzenText Text="DMV Codes" Style="font-weight: 600;" />
        <AuthorizeView Policy="@AppPermissions.DmvCodesManage">
            <RadzenButton Text="Add" Icon="add_circle" ButtonStyle="ButtonStyle.Primary" Click="AddAsync" />
        </AuthorizeView>
    </RadzenStack>

    <AppDataGrid @ref="_grid" TItem="Dmvcode" Data="_query" RowSelect="OnRowSelect">
        <Columns>
            <RadzenDataGridColumn TItem="Dmvcode" Property="DmvcodeType.DmvcodeType1" Title="DMV Code Type">
                <FilterTemplate>
                    <RadzenDropDown Data="_typeNames" Value="@context.FilterValue" Change="@(value => { context.FilterValue = value; _grid!.FirstPage(true); })" AllowFiltering="true" AllowClear="true" Style="width: 100%" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Dmvcode" Property="DmvcodeIdentifier" Title="Identifier" SortOrder="SortOrder.Ascending" />
            <RadzenDataGridColumn TItem="Dmvcode" Property="Dmvcode1" Title="DMV Code" />
        </Columns>
    </AppDataGrid>
</RadzenCard>

@code {
    private PMBContext? _db;
    private AppDataGrid<Dmvcode>? _grid;
    private IQueryable<Dmvcode>? _query;
    private List<string> _typeNames = [];

    protected override async Task OnInitializedAsync()
    {
        _db = await DbFactory.CreateDbContextAsync();
        _query = _db.Dmvcodes.AsNoTracking().Include(x => x.DmvcodeType);
        _typeNames = [.. _db.DmvcodeTypes.AsNoTracking().OrderBy(x => x.DmvcodeType1).Select(x => x.DmvcodeType1)];
    }

    private async Task AddAsync()
    {
        var result = await DialogService.OpenDialogAsync<DmvCodeDialog>("Add DMV Code");
        if (result is true)
            _db?.ChangeTracker.Clear();
    }

    private async Task OnRowSelect(Dmvcode row)
    {
        var result = await DialogService.OpenDialogAsync<DmvCodeDialog>("Edit DMV Code",
            new Dictionary<string, object?> { ["DmvcodeId"] = row.DmvcodeId });
        if (result is true)
            _db?.ChangeTracker.Clear();
    }
}

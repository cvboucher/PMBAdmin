@inject IDbContextFactory<PMBContext> DbFactory
@inject DialogService DialogService

<RadzenTemplateForm Data="_model" Submit="@((BatchJobType _) => SaveAsync())">
    <RadzenStack Gap="0.75rem">
        <RadzenFormField Text="Batch Job Type" AllowFloatingLabel="false">
            <RadzenTextBox @bind-Value="_model.BatchJobType1" Style="width: 100%" />
        </RadzenFormField>
        <RadzenFormField Text="Code" AllowFloatingLabel="false">
            <RadzenTextBox @bind-Value="_model.BatchJobTypeCode" Style="width: 100%" />
        </RadzenFormField>
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" class="rz-mt-3">
        <AuthorizeView Context="authContext" Policy="@AppPermissions.BatchJobTypesManage">
            <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Click="DeleteAsync" Visible="@(_model.BatchJobTypeId != 0)" />
            <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" />
        </AuthorizeView>
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="() => DialogService.Close()" />
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public int? BatchJobTypeId { get; set; }

    private PMBContext? _db;
    private BatchJobType _model = new();

    protected override async Task OnInitializedAsync()
    {
        _db = await DbFactory.CreateDbContextAsync();
        if (BatchJobTypeId.HasValue)
        {
            var existing = await _db.BatchJobTypes.FirstOrDefaultAsync(x => x.BatchJobTypeId == BatchJobTypeId.Value);
            if (existing != null)
                _model = existing;
        }
    }

    private async Task SaveAsync()
    {
        if (_model.BatchJobTypeId == 0)
            _db!.BatchJobTypes.Add(_model);
        else
            _db!.BatchJobTypes.Update(_model);

        await _db!.SaveChangesAsync();
        DialogService.Close(true);
    }

    private async Task DeleteAsync()
    {
        var confirmed = await DialogService.Confirm("Delete this batch job type?", "Confirm",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });
        if (confirmed != true) return;

        _db!.BatchJobTypes.Remove(_model);
        await _db.SaveChangesAsync();
        DialogService.Close(true);
    }
}
